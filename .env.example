# Copy this file to .env.local and fill all required values.
# Never commit .env.local or production secrets.

# Core Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# App URL (required)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# WhatsApp payment flow (required)
WHATSAPP_PAYMENT_NUMBER=9198XXXXXXXX
WHATSAPP_COORDINATOR_NAME=Coordinator Name

# Optional: used by register page to instantly open WhatsApp before API response
NEXT_PUBLIC_WHATSAPP_PAYMENT_NUMBER=9198XXXXXXXX

# Ticket email delivery (required for email notifications)
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=noreply@example.com
BREVO_SENDER_NAME=Manthan 2k26 Team

# Legacy Razorpay compatibility (optional but required for verify/webhook flows)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# Optional script-only credentials for ops automation
ADMIN_ACCOUNT_EMAIL=admin@manthan.in
ADMIN_ACCOUNT_PASSWORD=change_this_admin_password
ADMIN_ACCOUNT_NAME=Manthan Admin

VIEWER_ACCOUNT_EMAIL=viewer@manthan.in
VIEWER_ACCOUNT_PASSWORD=change_this_viewer_password
VIEWER_ACCOUNT_NAME=Manthan Viewer

# Optional for webhook simulation script
SIMULATE_WEBHOOK_SERVER_URL=http://localhost:3000
SIMULATE_WEBHOOK_ORDER_ID=order_example
SIMULATE_WEBHOOK_PAYMENT_ID=pay_example
